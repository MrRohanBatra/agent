      .search-box input {\n            flex: 1;\n        }\n        table {\n            width: 100%;\n            border-collapse: collapse;\n            margin-top: 20px;\n        }\n        th, td {\n            padding: 12px;\n            text-align: left;\n            border-bottom: 1px solid #ddd;\n        }\n        th {\n            background-color: #343a40;\n            color: white;\n        }\n        tr:hover {\n            background-color: #f8f9fa;\n        }\n        .action-buttons {\n            display: flex;\n            gap: 5px;\n        }\n        .btn-delete {\n            background-color: #dc3545;\n        }\n        .btn-delete:hover {\n            background-color: #c82333;\n        }\n        .empty-message {\n            text-align: center;\n            color: #777;\n            padding: 40px;\n        }\n    </style>\n</head>\n<body>\n    <div class="container">\n        <h1>Student Record Management System</h1>\n        \n        <div class="form-section">\n            <form id="studentForm">\n                <div class="form-group">\n                    <label for="rollNumber">Roll Number</label>\n                    <input type="number" id="rollNumber" name="rollNumber" required min="100">\n                </div>\n                <div class="form-group">\n                    <label for="name">Name</label>\n                    <input type="text" id="name" name="name" required placeholder="Enter student name">\n                </div>\n                <div class="form-group">\n                    <label for="department">Department</label>\n                    <select id="department" name="department" required>\n                        <option value="">Select Department</option>\n                        <option value="Computer Science">Computer Science</option>\n                        <option value="Information Technology">Information Technology</option>\n                        <option value="Electronics">Electronics</option>\n                        <option value="Mechanical Engineering">Mechanical Engineering</option>\n                        <option value="Civil Engineering">Civil Engineering</option>\n                        <option value="Biology">Biology</option>\n                        <option value="Chemistry">Chemistry</option>\n                        <option value="Physics">Physics</option>\n                    </select>\n                </div>\n                <div class="form-group">\n                    <label for="marks">Marks</label>\n                    <input type="number" id="marks" name="marks" required min="0" max="100">\n                </div>\n                <button type="submit">Add Student</button>\n            </form>\n        </div>\n\n        <div class="search-section">\n            <div class="search-box">\n                <input type="text" id="searchInput" placeholder="Search by name or roll number...">\n                <button onclick="searchStudents()">Search</button>\n            </div>\n        </div>\n\n        <table id="studentTable">\n            <thead>\n                <tr>\n                    <th>Roll Number</th>\n                    <th>Name</th>\n                    <th>Department</th>\n                    <th>Marks</th>\n                    <th>Action</th>\n                </tr>\n            </thead>\n            <tbody id="studentTableBody">\n            </tbody>\n        </table>\n    </div>\n\n    <script>\n        let students = [];\n        \n        // Load records from localStorage on page load\n        document.addEventListener(\'DOMContentLoaded\', function() {\n            const storedRecords = localStorage.getItem(\'studentRecords\');\n            if (storedRecords) {\n                students = JSON.parse(storedRecords);\n                renderTable();\n            } else {\n                addStudent({ rollNumber: 100, name: \'John Doe\', department: \'Computer Science\', marks: 85 });\n            }\n        });\n\n        // Add student to array and save to localStorage\n        document.getElementById(\'studentForm\').addEventListener(\'submit\', function(e) {\n            e.preventDefault();\n            \n            const newStudent = {\n                rollNumber: parseInt(document.getElementById(\'rollNumber\').value),\n                name: document.getElementById(\'name\').value,\n                department: document.getElementById(\'department\').value,\n                marks: parseInt(document.getElementById(\'marks\').value)\n            };\n\n            students.push(newStudent);\n            saveToLocalStorage();\n            renderTable();\n            \n            // Reset form\n            this.reset();\n        });\n\n        // Delete student from array and localStorage\n        function deleteStudent(index) {\n            students.splice(index, 1);\n            saveToLocalStorage();\n            renderTable();\n        }\n\n        // Save to localStorage\n        function saveToLocalStorage() {\n            localStorage.setItem(\'studentRecords\', JSON.stringify(students));\n        }\n\n        // Render table from students array\n        function renderTable() {\n            const tbody = document.getElementById(\'studentTableBody\');\n            tbody.innerHTML = \'\';\n\n            if (students.length === 0) {\n                tbody.innerHTML = \'<tr><td colspan="5" class="empty-message">No students found. Add a student to get started!</td></tr>\';\n                return;\n            }\n\n            students.forEach((student, index) => {\n                const row = document.createElement(\'tr\');\n                row.innerHTML = `\n                    <td>${student.rollNumber}</td>\n                    <td>${student.name}</td>\n                    <td>${student.department}</td>\n                    <td>${student.marks}</td>\n                    <td class="action-buttons">\n                        <button onclick="deleteStudent(${index})" class="btn-delete">Delete</button>\n                    </td>\n                `;\n                tbody.appendChild(row);\n            });\n        }\n\n        // Search students by name or roll number\n        function searchStudents() {\n            const searchTerm = document.getElementById(\'searchInput\').value.toLowerCase();\n            \n            const filteredStudents = students.filter(student => \n                student.name.toLowerCase().includes(searchTerm) || \n                student.rollNumber.toString().includes(searchTerm)\n            );\n\n            renderTable(filteredStudents);\n        }\n\n        // Add a new student to the array (for testing purposes)\n        function addStudent(data) {\n            students.push(data);\n            saveToLocalStorage();\n            renderTable();\n        }\n\n        // Initialize with some sample data if empty\n        if (students.length === 0) {\n            addStudent({ rollNumber: 100, name: \'John Doe\', department: \'Computer Science\', marks: 85 });\n            addStudent({ rollNumber: 101, name: \'Jane Smith\', department: \'Information Technology\', marks: 92 });\n            addStudent({ rollNumber: 102, name: \'Robert Johnson\', department: \'Electronics\', marks: 78 });\n        }\n    </script>\n</body>\n</html>\n'}
